SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Required for any send-capable scenario.
CONFIRM=I CONFIRM SANDBOX

# Operator-confirmed backend checklist. The harness cannot read these private
# dashboard settings through the anon key, so preflight refuses to run until
# you explicitly confirm them here.
SMS_PROVIDER_TWILIO_ENABLED=0
TWILIO_MESSAGING_SERVICE_CONFIGURED=0
A2P_10DLC_APPROVED=0
SMS_PUMPING_PROTECTION_ON=0
GEO_PERMISSIONS_US_CA_ONLY=0
TEST_OTPS_CONFIGURED=0
RESEND_COOLDOWN_SECONDS=30

# Hard safety budget for this local stress-test session.
OTP_SEND_BUDGET_MAX=2000

# T7 is never run by "all"; it also requires stdin confirmation.
REAL_PHONE_OPT_IN=0
REAL_PHONE_E164=

# Optional local tuning. Defaults match the prompt.
OTP_T2_RPS=20
OTP_T2_DURATION_SECONDS=60
OTP_T8_MINUTES=30
